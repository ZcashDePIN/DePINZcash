# DePINZcash web — copy to web/.env.local and edit.
VITE_API_URL=http://localhost:3000
VITE_ZCASH_NETWORK=mainnet
VITE_SOLANA_CLUSTER=devnet

# Optional: surface a treasury / dev wallet's live balances on the Home page.
# Leave empty to hide the section.
VITE_VAULT_WALLET=
VITE_VAULT_LABEL=Dev / treasury wallet
